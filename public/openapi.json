        "required": [
          "id",
          "restaurantId",
          "categoryId",
          "name",
          "description",
          "preparationTime",
          "calories",
          "dietary",
          "imageUrl",
          "popular",
          "price",
          "isAvailable",
          "createdAt"
        ]
      },
      "menuItemSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Menu item name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Menu item description"
          },
          "categoryId": {
            "type": "string",
            "description": "Category ID"
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "description": "Price"
          },
          "preparationTime": {
            "type": "number",
            "minimum": 0,
            "description": "Preparation time in minutes"
          },
          "calories": {
            "type": "number",
            "minimum": 0,
            "description": "Calories"
          },
          "dietary": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Dietary tags"
          },
          "imageUrl": {
            "type": "string",
            "description": "Image URL"
          },
          "popular": {
            "type": "boolean",
