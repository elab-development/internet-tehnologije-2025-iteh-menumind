            "type": "boolean",
            "description": "Popular flag"
          },
          "price": {
            "type": "string",
            "description": "Price"
          },
          "isAvailable": {
            "type": "boolean",
            "description": "Availability flag"
          },
          "createdAt": {
            "type": "object",
            "nullable": true,
            "description": "Created timestamp"
          }
