    "/categories/{id}": {
      "put": {
        "operationId": "updateCategory",
        "summary": "Update category\r",
        "description": "Updates an existing category belonging to authenticated restaurant",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
