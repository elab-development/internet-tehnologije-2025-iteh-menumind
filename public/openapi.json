        "required": [
          "id"
        ]
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Operation success flag"
          }
        },
        "required": [
          "success"
        ]
      },
      "ChatRequestSchema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessageSchema"
