        "properties": {
          "id": {
            "type": "string",
            "description": "Category ID"
          },
          "restaurantId": {
            "type": "string",
            "description": "Restaurant ID"
          },
          "name": {
            "type": "string",
            "description": "Category name"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Category description"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether category is active"
          },
          "createdAt": {
            "type": "object",
            "nullable": true,
            "description": "Created timestamp"
          }
        },
        "required": [
          "id",
          "restaurantId",
          "name",
          "description",
          "isActive",
          "createdAt"
        ]
      },
      "categorySchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Category name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Category description"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether category is active"
          }
        },
        "required": [
          "name",
          "description"
        ]
      },
      "CategoryParams": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Category ID"
          }
