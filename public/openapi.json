        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Restaurant ID"
          },
          "name": {
            "type": "string",
            "description": "Restaurant name"
          },
          "slug": {
            "type": "string",
            "description": "Restaurant slug"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Restaurant description"
          },
          "themeColor": {
            "type": "string",
            "nullable": true,
