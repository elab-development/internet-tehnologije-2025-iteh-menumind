          "signature": {
            "type": "string",
            "description": "Cloudinary API signature"
          },
          "cloudName": {
            "type": "string",
            "description": "Cloudinary cloud name"
          },
          "apiKey": {
            "type": "string",
            "description": "Cloudinary API key"
          },
          "folder": {
            "type": "string",
            "description": "Target upload folder"
          }
